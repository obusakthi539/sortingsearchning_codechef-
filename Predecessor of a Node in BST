class Solution {
    public int getPredecessor(Node root, int x) {
      Node predecessor=null;
      while(root!=null) {
          if(root.val<x){
              predecessor=root;
              root=root.right;
          } root=root.left;
      }if(predecessor==null){
          return -1;
      }else{
          return predecessor.val;
      } }
}



