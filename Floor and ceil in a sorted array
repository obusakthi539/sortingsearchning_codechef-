class Solution {
    public int[] findFloorCeil(int[] arr, int k) {
        int n=arr.length;
        int c=-1,f=-1;
        int left=0,right=n-1;
        while(left<=right)
        {
            int mid=(left+right)/2;
            if(arr[mid]==k)
            {
                f=arr[mid];
                c=arr[mid];
                return new int[]{f,c};
            }
            else if(arr[mid]<k)
            {
                f=arr[mid];
                left=mid+1;
            }
            else 
            {
                c=arr[mid];
                right=mid-1;
            }
        }
        return new int[]{f,c};
    }
}







class Solution {
    public int[] findFloorCeil(int[] arr, int k) {
        int n=arr.length;
        int l=0,r=n-1,f=-1,c=-1;
        while (l<=r){
            int mid=(l+r)/2;
            if(arr[mid]==k){
                f=arr[mid];
                c=arr[mid];
                return new int[]{f,c};
            }
            else if(k<arr[mid]){
                c=arr[mid];
                r=mid-1;
            }
            else{
                f=arr[mid];
                l=mid+1;
            }
        }
        return new int[]{f,c};
    }
}

