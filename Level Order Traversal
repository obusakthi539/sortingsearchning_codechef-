class Solution {
    public void levelOrderTraversal(Node root) {
        if(root == null) return;
        Queue<Node> q = new LinkedList<>();

        q.add(root);
        q.add(null);

        while(!q.isEmpty()){

            Node curr = q.poll();

            if(curr == null){
                System.out.println();

                if(!q.isEmpty())
                    q.add(null);
            }
            else{

                System.out.print(curr.val + " ");

                if(curr.left != null)
                    q.add(curr.left);

                if(curr.right != null)
                    q.add(curr.right);
            }
        }
    }
}
