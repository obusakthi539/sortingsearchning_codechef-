public static void selectionSort(int[] a) {
    int n=a.length;
    for(int i=0;i<n-1;i++){
        int minIndex=i;
        for(int j=i+1;j<n;j++){
            if(a[j]<a[minIndex])
            {
                minIndex=j;
            } }  }
       int t=a[i];
       a[i]=a[minIndex];
       a[minIndex]=t;
}




