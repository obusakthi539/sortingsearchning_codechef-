 static int upperBound(int[] nums, int x) {
        int left=0;
        int right=nums.length-1;
        int a=nums.length;
        while(left<=right)
        {
            int mid=(left+right)/2;
            if(nums[mid]>x)
            {
                a=mid;
                right=mid-1;
            }
            else{
                left=mid+1;
            }
        } return a;
    }
